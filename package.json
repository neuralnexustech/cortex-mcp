    "url": "https://github.com/neuralnexustech/cortex-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "memory",
    "cortex",
    "claude",
    "gemini",
    "codex",
    "cursor",
    "opencode",
    "skill",
    "dashboard",
    "knowledge-graph",
    "search"
  ],
  "author": "neuralnexustech",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
